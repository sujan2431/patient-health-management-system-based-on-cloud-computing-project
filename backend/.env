PORT=4001

# Secret used to sign/verify JWT tokens — change this to a long random string in production
JWT_SECRET=super-secret-dev-key-change-me

# MySQL / MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=phms

# Optional: AWS S3 for report file uploads (leave blank if unused locally)
S3_BUCKET=phms-reports-bucket
AWS_REGION=ap-south-1
