NODE_ENV=development
PORT=4000

# Use SQLite for local by default
DB_CLIENT=sqlite
DB_FILE=./data/phms.sqlite

# For MySQL, switch DB_CLIENT=mysql and fill these:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=yourpassword
# DB_NAME=phms

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Required to register Admin/Doctor accounts
INVITE_CODE=CHANGE_ME_INVITE

# Optional OpenAI integration for AI report summaries
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional
CORS_ORIGIN=http://localhost:5173

# Shown in SMS when linking a patient user (use your deployed frontend URL in production)
PATIENT_PORTAL_URL=http://localhost:5173

# Optional Twilio — set all three to send real SMS on patient link; otherwise SMS is logged only
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567

# On first startup with an empty `users` table, demo accounts are created:
#   admin@hospital.com, doctor@hospital.com, patient@hospital.com
#   Password for all: Password1!

